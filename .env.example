# TeamNoT environment variables — copy to .env and fill in.
# Loaded via python-dotenv at CLI startup.

# ── Cost-metered API keys ─────────────────────────────────────────────────────
# Only set the ones you intend to use. The brief's `allowed_metered_workers`
# allow-list is the real gate; setting a key here without opting in via brief
# does nothing.

MINIMAX_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=     # only for ANTHROPIC API (metered). Claude Code CLI uses OAuth.

# ── Telegram gateway ──────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
# Optional: comma-separated list of chat IDs allowed to talk to the bot.
TEAMNOT_TELEGRAM_ALLOWED_CHATS=

# ── Skills override ───────────────────────────────────────────────────────────
# Point at a custom skills directory; falls back to bundled `skills/`.
TEAMNOT_SKILLS_DIR=

# ── Logging ───────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR. Default: INFO
TEAMNOT_LOG_LEVEL=
